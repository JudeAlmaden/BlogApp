<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteBase /BlogApp/

    # Exclude /public/ and subdirectories from rewrite
    RewriteCond %{REQUEST_URI} ^/BlogApp/public/
    RewriteCond %{REQUEST_URI} !^/BlogApp/public/uploads/
    RewriteCond %{REQUEST_URI} !^/BlogApp/public/uploads/media
    RewriteRule ^ - [L]

    # Exclude static files (like images, CSS, JS) from being routed through index.php
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^(.*)$ - [L]

    # Redirect all other requests to index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>
